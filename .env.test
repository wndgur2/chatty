MYSQL_ROOT_PASSWORD=chatty_root
MYSQL_DATABASE=chatty
DATABASE_URL=mysql://root:chatty_root@mysql:3306/chatty

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

PUBLIC_ORIGIN=http://localhost:8080
CORS_ORIGIN=http://localhost:8080

OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen2.5:1.5b
OLLAMA_EVAL_MODEL=qwen2.5:1.5b
OLLAMA_EMBED_MODEL=all-minilm
OLLAMA_STRUCTURED_OUTPUT_MODEL=

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=chat_memory
RAG_RECENT_WINDOW=8
RAG_TOP_K=5
RAG_MIN_SCORE=0.4
RAG_SNIPPET_CHARS=200
RAG_CHUNK_MIN_CHARS=8
RAG_CHUNK_MIN_SENTENCES=0
RAG_CHUNK_BUFFER_SIZE=1
RAG_CHUNK_BREAKPOINT_PERCENTILE=95
RAG_CHUNK_MAX_CHARS=24
RAG_CHUNK_OVERLAP_CHARS=6

MEMORY_EXTRACTOR_MIN_CONFIDENCE=0.4
MEMORY_EXTRACTOR_MAX_OPS_PER_TURN=10
MEMORY_RETRIEVER_MIN_CONFIDENCE=0.5

FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

VITE_API_URL=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FCM_VAPID_KEY=

HTTP_PORT=8080
