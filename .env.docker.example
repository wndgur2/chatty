# Copy to `.env` in the project root and adjust values.
# Usage: docker compose --env-file .env up --build

# --- MySQL (must match DATABASE_URL password) ---
MYSQL_ROOT_PASSWORD=chatty_root
MYSQL_DATABASE=chatty

# Prisma / Nest (hostname `mysql` is the Compose service name)
DATABASE_URL=mysql://root:chatty_root@mysql:3306/chatty

# --- Backend ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Browser-facing origin (must match how you open the app). Used for CORS and baked into the frontend build.
PUBLIC_ORIGIN=http://localhost:8080
CORS_ORIGIN=http://localhost:8080

# Ollama on the Mac host (Docker Desktop provides host.docker.internal).
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen2.5:1.5b
OLLAMA_EVAL_MODEL=qwen2.5:1.5b
OLLAMA_EMBED_MODEL=all-minilm

# Qdrant (vector storage for long-term memory retrieval)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=chat_memory
RAG_RECENT_WINDOW=8
RAG_TOP_K=5
RAG_MIN_SCORE=0.4
RAG_SNIPPET_CHARS=200
MEMORY_EXTRACTOR_ENABLED=true
MEMORY_EXTRACTOR_INCLUDE_AI_TURNS=false
MEMORY_RETRIEVER_ENABLED=true
MEMORY_RETRIEVER_CANDIDATE_LIMIT=8
MEMORY_RETRIEVER_FINAL_LIMIT=5
MEMORY_STATE_DEFAULT_TTL_SECONDS=0
MEMORY_RETRIEVER_TOKEN_BUDGET=1800
RAG_CHUNK_MIN_CHARS=8
RAG_CHUNK_MIN_SENTENCES=0
RAG_CHUNK_BUFFER_SIZE=1
RAG_CHUNK_BREAKPOINT_PERCENTILE=95
RAG_CHUNK_MAX_CHARS=24
RAG_CHUNK_OVERLAP_CHARS=6

# FCM (optional). Either set JSON inline or mount a file and set GOOGLE_APPLICATION_CREDENTIALS inside the container.
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# --- Frontend build args (optional; same as local Vite names) ---
VITE_API_URL=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FCM_VAPID_KEY=

# Published HTTP port on the host (nginx).
HTTP_PORT=8080
